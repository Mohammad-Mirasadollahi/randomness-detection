# =============================================================================
# Randomness Detection — environment configuration
# =============================================================================
#
# HOW TO USE THIS FILE
# --------------------
# 1. First install (recommended):  ./install.sh
#    install.sh creates .env automatically with a secure API key.
#
# 2. Manual setup:  cp .env.example .env  &&  ./install.sh --write-api-key
#
# 3. install.sh auto-configures your shell (~/.config/randomness_detection/env.sh).
#    No need to run: source .env  or  source .venv/bin/activate
#    CLI commands load .env automatically.
#
# 4. After ANY change to this file, restart the server:
#      ./install.sh --stop && ./install.sh
#    Or for systemd:  sudo systemctl restart randomness-detection
#
# 5. Test the API (RANDOMNESS_API_KEY is available automatically in new shells):
#      curl -s http://127.0.0.1:8765/health
#      curl -s -X POST http://127.0.0.1:8765/score \
#        -H "Authorization: Bearer $RANDOMNESS_API_KEY" \
#        -H "Content-Type: application/json" \
#        -d '{"text":"hello"}'
#
# SECURITY: keep this file private (chmod 600). Never commit .env to git.
# =============================================================================


# --- Authentication (required) -----------------------------------------------
# Secret key for API access. Minimum 32 characters.
# Generate a new key:  ./install.sh --gen-api-key
# Save to this file:   ./install.sh --write-api-key
# Rotate existing:     ./install.sh --rotate-api-key  (then restart server)
#
# Use in requests:
#   Authorization: Bearer <key>     OR     X-API-Key: <key>
RANDOMNESS_API_KEY=change-me-to-a-secret-key-at-least-32-characters-long

# Dev only — disable auth entirely (NEVER use in production):
# RANDOMNESS_ALLOW_NO_AUTH=true


# --- Network / API server ----------------------------------------------------
# RANDOMNESS_HOST — address the server listens on.
#   0.0.0.0  = all interfaces (default; reachable from LAN/internet if firewall allows)
#   127.0.0.1 = localhost only (safest for single-machine use)
RANDOMNESS_HOST=0.0.0.0

# RANDOMNESS_PORT — TCP port for the API (default 8765).
RANDOMNESS_PORT=8765

# RANDOMNESS_LOG_LEVEL — uvicorn log verbosity: critical, error, warning, info, debug
# RANDOMNESS_LOG_LEVEL=info

# RANDOMNESS_UVICORN_WORKERS — number of API worker processes (default 1).
# Increase on multi-core servers; each worker loads its own model copy.
RANDOMNESS_UVICORN_WORKERS=1


# --- Model cache & data paths ------------------------------------------------
# Directory for trained model, word corpus, frequency table, and exclude DB.
# Created automatically on first install / bootstrap.
RANDOMNESS_CACHE_DIR=.cache

# Override exclude-database location (default: $RANDOMNESS_CACHE_DIR/exclude.db):
# RANDOMNESS_EXCLUDE_DB_PATH=.cache/exclude.db


# --- Parallel scoring (CPU) --------------------------------------------------
# Backend for inference pool: process | thread | hybrid (recommended)
RANDOMNESS_PARALLEL_BACKEND=hybrid

# Worker counts — install.sh sets these to your CPU count (capped at 24).
# Increase for more throughput; decrease to leave CPU for other apps.
RANDOMNESS_INFERENCE_WORKERS=24
RANDOMNESS_INFERENCE_THREADS=24

# Fraction of CPUs used for inference (0.1–1.0). Default in code: 1.0
# RANDOMNESS_INFERENCE_CPU_FRACTION=1.0


# --- Exclusion rules & score cache -------------------------------------------
# Skip scoring for strings matching exclude rules (domains, suffixes, etc.).
# Manage rules via API: POST /exclude  (see Docs/exclusion.md)
RANDOMNESS_EXCLUDE_ENABLED=true

# Cache low scores so identical strings are not re-scored (fast path).
RANDOMNESS_SKIP_CACHE_ENABLED=true

# Re-use cached score without re-inference when cached score <= this value (1–100).
RANDOMNESS_SKIP_SCORE_THRESHOLD=30


# --- Internal (set by install.sh — do not change unless you know why) --------
# Required for CLI and server to find the Python package.
PYTHONPATH=.
